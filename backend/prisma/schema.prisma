generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum ProductPlacement {
  SHOWCASE
  GRID
}

model Category {
  id           Int                   @id @default(autoincrement())
  slug         String                @unique
  imgUrl       String
  parentId     Int?
  level        Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  parent       Category?             @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]            @relation("CategoryTree")
  translations CategoryTranslation[]
  products     Product[]
}

model CategoryTranslation {
  id         Int      @id @default(autoincrement())
  categoryId Int
  locale     String
  name       String
  slug       String

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@unique([locale, slug])
}

model Product {
  id              Int                  @id @default(autoincrement())
  slug            String?              @unique
  placement       ProductPlacement
  badgeColor      String
  titleColor      String
  descColor       String
  btn1Color       String
  btn1BgColor     String
  btn2Color       String
  btn2BgColor     String
  imgUrl          String
  backgroundColor String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  categories      Category[]
  translations    ProductTranslation[]
  orders          ProductOrder[]
  contents        ProductContent[]
}

model ProductContent {
  id        Int      @id @default(autoincrement())
  productId Int
  locale    String
  blocks    Json     @default("[]")
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model ProductOrder {
  id        Int      @id @default(autoincrement())
  productId Int
  name      String
  phone     String
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductTranslation {
  id        Int     @id @default(autoincrement())
  productId Int
  locale    String
  badge     String?
  title     String
  desc      String  @db.Text

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model HeroSlide {
  id            Int                    @id @default(autoincrement())
  videoSrc      String
  eyebrowColor  String
  headlineColor String
  sublineColor  String
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  translations  HeroSlideTranslation[]
}

model HeroSlideTranslation {
  id          Int       @id @default(autoincrement())
  heroSlideId Int
  locale      String
  eyebrow     String
  headline    String    @db.Text
  subline     String    @db.Text

  heroSlide   HeroSlide @relation(fields: [heroSlideId], references: [id], onDelete: Cascade)

  @@unique([heroSlideId, locale])
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model StaffMember {
  id           Int                      @id @default(autoincrement())
  imageUrl     String
  order        Int                      @default(0)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  translations StaffMemberTranslation[]
}

model StaffMemberTranslation {
  id            Int         @id @default(autoincrement())
  staffMemberId Int
  locale        String
  name          String
  position      String

  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@unique([staffMemberId, locale])
}

model CompanyInfo {
  id           Int      @id @default(1)
  latitude     Decimal  @db.Decimal(10, 8)
  longitude    Decimal  @db.Decimal(11, 8)
  address      String
  phoneNumber  String
  email        String
  startDay     Int      @default(1)
  endDay       Int      @default(5)
  startAt      String   @default("09:00")
  endAt        String   @default("18:00")
  updatedAt    DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

