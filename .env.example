# Your domain (e.g. example.com — no https://, no trailing slash)
DOMAIN=yourdomain.com

# Public API URL — must be https://api.<your-domain>/api
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# Yandex Maps API key (copy from frontend/.env)
NEXT_PUBLIC_YMAPS_API_KEY=

# MySQL root password
MYSQL_ROOT_PASSWORD=root

# Backend secrets
JWT_SECRET=change-me-to-a-long-random-string

# Admin credentials
ADMIN_EMAIL=admin@example.com
# Generate hash: cd backend && npm run hash-password -- yourpassword
ADMIN_PASSWORD_HASH=$2b$12$Nh4gtSs/ZAQpMYFMDpNMrOmNuZzFKtDUSrWT5X9b1ZpgvYaC0OpXi

# Cloudflare Tunnel token (from dash.cloudflare.com → Zero Trust → Networks → Tunnels)
CLOUDFLARE_TUNNEL_TOKEN=
