# Public API base (browser + server). Include /api prefix.
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Optional: server-only override if it differs from NEXT_PUBLIC_API_URL
# API_URL=http://127.0.0.1:4000/api

# Backend base URL used for proxying /uploads in next.config.ts
BACKEND_URL=http://localhost:4000
